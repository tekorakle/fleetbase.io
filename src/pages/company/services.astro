---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import ServicesGrid from '@components/company/servicesgrid.astro'
import PricingTable from '@components/pricing/PricingTable.astro'
import Faq from '@components/shared/Faq.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import { SITE } from '@config'
---

<RootLayout
  title={`Services | ${SITE.title}`}
  description="Additional services offered for open source version of Fleetbase"
>
  <HeroContainer>
    <ServicesGrid />
    <Divider />
    <Footer />
  </HeroContainer>
</RootLayout>
