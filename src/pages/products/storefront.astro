---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import HomeHero from '@components/home/HomeHero.astro'
import BentoGridSection from '@components/home/BentoGridSection.astro'
import CodeSnippets from '@components/home/CodeSnippets.astro'
import Integrations from '@components/home/Integrations.astro'
import StorefrontFeatures from '@components/products/storefront-features.astro'
import Testimonials from '@components/home/Testimonials.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import { SITE } from '@config'
---

<RootLayout
  title={`Storefront | ${SITE.title}`}
  description="Open source headless eccommerce extension for marketplace and on demand delivery"
>
  <HeroContainer>
    <StorefrontFeatures />
    <Divider />
    <Footer />
  </HeroContainer>
</RootLayout>
