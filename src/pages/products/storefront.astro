---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import Button from '@components/shared/Button.astro'
import { SITE } from '@config'
import { Image } from 'astro:assets'
import StorefrontHero from '@components/products/storefront-hero.astro'
import StorefrontFeature from '@components/products/storefront-feature.astro'
import inventoryGraphic from '@images/screenshots/storefront-screenshot-product-edit-zoom.png'
import networkGraphic from '@images/screenshots/storefront-screenshot-network-settings.png'
import zoneGraphic from '@images/screenshots/fleetops-screenshot-service-area.png'
import i18nGraphic from '@images/screenshots/storefront-screenshot-i18n.png'
import trueVeganScreenshot from '@images/screenshots/true-vegan-screenshot.png'
import oliMaxScreenshot from '@images/screenshots/oli-max-screenshot.png'
import addToCartAnimation_webm from '@animations/storefront-app-add-to-cart.webm'
import addToCartAnimation_mp4 from '@animations/storefront-app-add-to-cart.mp4'
import foodTruckAnimation_mp4 from '@animations/storefront-food-truck.mp4'
---

<RootLayout
	title={`${SITE.title} - Framework`}
	description="Storefront by Fleetbase is a logistics-first, headless ecommerce platform designed for hyperlocal commerce — power real-time inventory, delivery, and order tracking for food, retail, and on-demand services"
>
	<HeroContainer>
		<StorefrontHero />
	</HeroContainer>
	<Divider />
	<StorefrontFeature
		title={['Inventory Made Easy —', 'Powered by Pallet']}
		description="Storefront integrates seamlessly with Fleetbase’s Pallet extension to give you complete inventory control across your stores, food trucks, or dark stores."
		points={[
			'Real-time inventory sync via Pallet backend',
			'Manage SKUs, stock levels, batches, and expiry dates',
			'Visual interface for tracking and updating stock',
			'Location-aware inventory availability',
		]}
		image={inventoryGraphic}
		mediaType="background"
		mediaHeight={600}
		mediaScale={2.9}
		sectionClass="border-b border-zinc-800 py-20"
	/>
	<Divider />
	<StorefrontFeature
		title={['Smarter Delivery', 'with Fleet-Ops powered Zones']}
		description="Define geographic zones and service rates for hyperlocal delivery via Fleet-Ops, and let Storefront automatically apply dynamic pricing and time estimates based on distance and demand."
		points={[
			'Draw and assign delivery zones visually',
			'Set pricing per zone, distance, or store',
			'Zone-level delivery ETAs and rules',
		]}
		image={zoneGraphic}
		mediaType="background"
		mediaHeight={600}
		mediaScale={2.9}
		mediaFocus="center"
		mediaPosition="left"
		sectionClass="border-b border-zinc-800 py-20"
	/>
	<Divider />
	<StorefrontFeature
		title={['Launch Your Own App', '— Instantly']}
		description="Give your customers a fully-branded mobile experience with ordering, notifications, and tracking — powered by Fleetbase’s native mobile stack."
		points={[
			'Branded iOS/Android app ready to deploy',
			'Order tracking, push notifications, and payments',
			'Perfect for restaurants, grocers, and delivery shops',
			'Supports service scheduling, and multi-vender marketplace',
		]}
		mediaType="custom"
	>
		<div slot="media" style="height: 470px; max-height: 470px;">
			<video
				autoplay
				loop
				muted
				playsinline
				style="background: none; height: 100%;"
			>
				<source src={addToCartAnimation_webm} type="video/webm" />
				<source src={addToCartAnimation_mp4} type="video/mp4" />
			</video>
		</div>
	</StorefrontFeature>
	<Divider />
	<StorefrontFeature
		title={['Global-Ready', 'with i18n and Multi-Currency']}
		description="Storefront is built for any market — support multiple languages and currencies with full translation of the interface, products, and order flows."
		points={[
			'Translate all frontend and app text with ease',
			'Full product catalog translation support',
			'Multi-currency pricing and Stripe integration',
			'Locale detection and currency switching',
		]}
		image={i18nGraphic}
		mediaType="background"
		mediaHeight={600}
		mediaScale={2.9}
		mediaFocus="center"
		mediaPosition="left"
		sectionClass="border-b border-zinc-800 py-20"
	/>
	<Divider />
	<StorefrontFeature
		title={['Build Your Own Marketplace —', 'Powered by Networks']}
		description="Storefront’s Networks feature allows you to create multi-vendor marketplaces, linking multiple stores under one network — enabling shared catalogs, multi-store carts, and unified checkout experiences."
		points={[
			'Create multi-vendor networks with multiple stores',
			'Support multi-store carts and unified checkout flows',
			'Manage independent stores under one marketplace umbrella',
			'Perfect for food delivery apps, local marketplaces, and on-demand platforms',
		]}
		image={networkGraphic}
		mediaType="background"
    mediaFocus="center"
		mediaHeight={600}
		mediaScale={2.9}
		sectionClass="border-b border-zinc-800 py-20"
	/>
	<Divider />
	<StorefrontFeature
		title={[
			'Launch Your Food Truck Empire',
			'— Menus, Apps, and Management in One.',
		]}
		description="Storefront empowers food truck owners to manage fleets, customize menus per truck, and instantly launch a customer-facing app — without the heavy development costs."
		points={[
			'Manage multiple food trucks and locations easily',
			'Assign custom menus to each food truck',
			'Deploy a branded iOS/Android app for ordering',
			'Streamlined inventory and order management',
		]}
		sectionClass="pt-20 pb-4"
		mediaPosition="none"
		contentSectionClass="w-full"
	/>
	<div class="container mx-auto flex flex-col items-center pb-20">
		<div
			style="height: 500px; max-height: 500px; overflow: hidden;"
			class="rounded-xl border border-gray-700 bg-zinc-900 shadow-xl"
		>
			<video
				autoplay
				loop
				muted
				playsinline
				style="background: none; height: 100%;"
			>
				<source src={foodTruckAnimation_mp4} type="video/mp4" />
			</video>
		</div>
	</div>
	<Divider />
	<section class="border-t border-zinc-800 bg-zinc-950 py-24">
		<div class="container mx-auto px-6 text-center">
			<div class="mb-4">
				<span class="relative inline-block px-1">
					<span
						class="relative z-10 bg-gradient-to-b from-blue-400 to-blue-500 bg-clip-text text-3xl font-bold text-transparent sm:text-4xl"
					>
						Storefront in the Wild
					</span>
					<span
						class="absolute -top-px left-0 -z-10 text-3xl font-bold text-blue-300 opacity-10 sm:text-4xl"
					>
						Storefront in the Wild
					</span>
				</span>
			</div>
			<p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-300">
				Trusted by forward-thinking businesses — from urban food trucks to
				high-volume local marketplaces. See how others are using Storefront to
				launch fast, manage smarter, and deliver faster.
			</p>

			<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
				<div class="rounded-xl border border-gray-800 bg-zinc-900 p-4 shadow">
					<Image
						src={oliMaxScreenshot}
						alt="OLI Max - Moving truck shop of Ulaanbaatar"
						class="h-auto w-full"
					/>
					<h3 class="text-xl font-semibold text-white">OLI Max</h3>
					<div class="mt-3 space-y-2 text-left">
						<p class="text-sm text-zinc-400">
							Ulaanbaatar’s first moving truck shop — browse local favorites,
							order from nearby trucks, and track your delivery live from truck
							to doorstep.
						</p>
						<p class="text-sm text-zinc-400">
							Chat with drivers, get real-time updates, and receive proof of
							delivery, all in one seamless experience.
						</p>
					</div>
					<div class="mt-4 grid grid-cols-1 gap-2 lg:grid-cols-2">
						<div class="">
							<Button
								href="https://apps.apple.com/us/app/oli-max/id6740000603"
								target="_appstore"
								variant="secondary"
								size="sm"
								class="w-full"
							>
								<span>App Store</span>
							</Button>
						</div>
						<div class="">
							<Button
								href="https://play.google.com/store/apps/details?id=com.olimax.app"
								target="_playstore"
								variant="secondary"
								size="sm"
								class="w-full"
							>
								<span>Play Store</span>
							</Button>
						</div>
					</div>
				</div>
				<div class="rounded-xl border border-gray-800 bg-zinc-900 p-4 shadow">
					<Image
						src={trueVeganScreenshot}
						alt="True Vegan - by Chef Rahein"
						class="h-auto w-full"
					/>
					<h3 class="text-xl font-semibold text-white">True Vegan</h3>
					<div class="mt-3 space-y-2 text-left">
						<p class="text-sm text-zinc-400">
							Founded by acclaimed vegan chef Rahein Jones, True Vegan lets
							locals enjoy their favorite plant-based dishes anytime — with
							real-time delivery, easy pickup options, and full order tracking
							through the app.
						</p>
					</div>
					<div class="mt-4 grid grid-cols-1 gap-2 lg:grid-cols-2">
						<div class="">
							<Button
								href="https://apps.apple.com/us/app/oli-max/id6740000603"
								target="_appstore"
								variant="secondary"
								size="sm"
								class="w-full"
							>
								<span>App Store</span>
							</Button>
						</div>
						<div class="">
							<Button
								href="https://play.google.com/store/apps/details?id=com.olimax.app"
								target="_playstore"
								variant="secondary"
								size="sm"
								class="w-full"
							>
								<span>Play Store</span>
							</Button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
	<Divider />
	<Footer />
</RootLayout>
