---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import DriverAppFeatures from '@components/products/driver-app-features.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import { SITE } from '@config'
import { Icon } from 'astro-icon/components'
import LottiePlayer from '@components/shared/LottiePlayer.astro'
import navigatorAppWebScroll from '@animations/navigator-app-web-scroll.json'

const content = [
	{
		title: ['Streamlined order handling', 'with built-in Navigation'],
		description:
			'Drivers can view, accept, and complete orders with full routing support using turn-by-turn navigation — all in one app.',
		points: [
			'Integrated turn-by-turn directions',
			'Auto-updating routes based on traffic',
			'One-tap order status updates and handoffs',
		],
		width: '50%',
		translateX: 100,
		start: 28,
		end: 48,
	},
	{
		title: ['Log issues and updates', 'in real-time'],
		description:
			'Navigator allows drivers to instantly flag order issues, submit proof, and chat directly with customers or dispatchers.',
		points: [
			'Real-time issue reporting with photo uploads',
			'In-app chat with customers and support teams',
			'Update order activities like delays or failed attempts',
		],
		width: '45%',
		translateX: -10,
		start: 49,
		end: 84,
	},
	{
		title: ['Proof of delivery', 'and real-time order tracking'],
		description:
			'Automatically capture signatures, photos, or scans for verified deliveries — while providing live order tracking to customers.',
		points: [
			'Signature, barcode, and photo-based delivery confirmation',
			'Live tracking links for customers',
			'Secure audit trail of each delivery attempt',
		],
		width: '50%',
		translateX: 0,
		start: 85,
		end: 108,
	},
]
---

<RootLayout
	title={`${SITE.title} - Navigator App`}
	description="Open source driver app for logistics operations."
>
	<HeroContainer id="animation-container">
		<div class="flex h-[120vh] justify-center">
			<div class="relative mt-48 flex flex-col items-center text-center">
				<h1
					class="max-w-5xl text-4xl font-bold leading-extratight text-blue-100 sm:text-5xl sm:leading-extratight"
				>
					Fleetbase Navigator<br />
					<span class="relative inline-block text-nowrap">
						<span
							class="relative z-10 bg-gradient-to-b from-blue-400 via-blue-400 to-blue-500 bg-clip-text text-transparent"
						>
							Driver App
						</span>
						<span class="absolute -top-px left-0 -z-10 text-blue-300">
							Driver App
						</span>
					</span>
				</h1>
				<p class="mt-5 max-w-xl text-lg leading-8 text-zinc-200">
					Built for operational efficiency and transparency, Navigator enables
					your drivers to execute deliveries with precision and real-time
					connectivity.
				</p>

				<!-- App Store Links + White Label Button -->
				<div
					class="mt-6 flex flex-col items-center justify-center gap-4 sm:flex-row"
				>
					<a
						href="https://apps.apple.com/us/app/fleetbase-navigator/id1554208255"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 rounded-full border border-white px-5 py-2 text-sm font-semibold text-white transition-all hover:bg-gray-300 hover:text-black"
					>
						<Icon name="nucleo/apple-fill-32" class="h-5 w-5" />
						Download on App Store
					</a>

					<a
						href="https://play.google.com/store/apps/details?id=io.fleetbase.navigator"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 rounded-full border border-white px-5 py-2 text-sm font-semibold text-white transition-all hover:bg-gray-300 hover:text-black"
					>
						<Icon name="nucleo/google" class="h-5 w-5" />
						Download on Play Store
					</a>

					<a
						href="https://tally.so/r/nrkVRM"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 rounded-full bg-pink-600 px-5 py-2 text-sm font-semibold text-white shadow-md transition-all hover:bg-pink-700"
					>
						<Icon name="heroicons:rocket-launch" class="h-4 w-4" />
						Publish White Label
					</a>
				</div>
			</div>
		</div>
		<div
			id="lottie-wrapper"
			class="pointer-events-none fixed inset-0 z-20 flex items-center justify-center"
		>
			<LottiePlayer
				name="navigator-app-web-scroll"
				animationData={navigatorAppWebScroll}
				autoplay={false}
				loop={false}
				class="w-full max-w-4xl"
			/>
		</div>
		{
			content.map((content) => (
				<div
					class={`content fixed left-0 top-1/3 translate-x-[${content.translateX}px] px-16 opacity-0 pointer-events-none`}
					data-start-frame={content.start}
					data-end-frame={content.end}
					data-direction="left"
					style={`width: ${content.width};`}
				>
					<h2 class="mb-4 text-3xl font-bold leading-tight text-blue-100 sm:text-4xl">
						{Array.isArray(content.title) ? (
							content.title.map((segment, i) =>
								i % 2 === 0 ? (
									<span>{segment}</span>
								) : (
									<span class="relative inline-block px-1">
										<span class="relative z-10 bg-gradient-to-b from-blue-400 to-blue-500 bg-clip-text text-transparent">
											{segment}
										</span>
										<span class="absolute -top-px left-0 -z-10 text-blue-300 opacity-10">
											{segment}
										</span>
									</span>
								)
							)
						) : (
							<span>{content.title}</span>
						)}
					</h2>
					<p class="mb-6 text-lg text-zinc-300">{content.description}</p>
					<ul class="mb-6 list-disc space-y-2 pl-5 text-zinc-100">
						{content.points.map((point) => (
							<li>{point}</li>
						))}
					</ul>
					<div class="mt-6 flex flex-col items-center justify-start space-x-3 sm:flex-row">
						<a
							href="https://apps.apple.com/us/app/fleetbase-navigator/id1554208255"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 rounded-full border border-white px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-gray-300 hover:text-black"
						>
							<Icon name="nucleo/apple-fill-32" class="h-5 w-5" />
							App Store
						</a>

						<a
							href="https://play.google.com/store/apps/details?id=io.fleetbase.navigator"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 rounded-full border border-white px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-gray-300 hover:text-black"
						>
							<Icon name="nucleo/google" class="h-5 w-5" />
							Play Store
						</a>

						<a
							href="https://tally.so/r/nrkVRM"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 rounded-full bg-pink-600 px-4 py-2 text-sm font-semibold text-white shadow-md transition-all hover:bg-pink-700"
						>
							<Icon name="heroicons:rocket-launch" class="h-4 w-4" />
							White Label
						</a>
					</div>
				</div>
			))
		}
		<div class="h-[580vh]"></div>
	</HeroContainer>
	<Divider />
	<div id="navigator-app-features">
    <DriverAppFeatures />
  </div>
	<Divider />
	<Footer />
</RootLayout>

<script type="module">
	if (window.lottie) {
		const animation = window.lottie
			.getRegisteredAnimations()
			.find((a) => a.name === 'navigator-app-web-scroll')

		const footer = document.getElementById('navigator-app-features')
		const lottieWrapper = document.getElementById('lottie-wrapper')
    const animationContainer = document.getElementById('animation-container')

		function updateAnimationFrame() {
			const scrollTop = window.scrollY
			const docHeight = animationContainer.scrollHeight - window.innerHeight

			// Calculate scroll progress
			const scrollProgress = Math.min(Math.max(scrollTop / docHeight, 0), 1)

			// Boost sensitivity slightly (optional, tuning factor)
			const boostedProgress = scrollProgress + 0.09

			// Calculate frame
			const frame = Math.min(
				boostedProgress * animation.totalFrames,
				animation.totalFrames - 1
			)

			animation.goToAndStop(frame, true)
			updateContentVisibility(frame)
			console.log('[frame]', frame)
		}

		function updateContentVisibility(frame) {
			const contents = document.querySelectorAll(
				'[data-start-frame][data-end-frame]'
			)

			contents.forEach((content) => {
				const start = parseInt(content.dataset.startFrame, 10)
				const end = parseInt(content.dataset.endFrame, 10)

				if (frame >= start && frame <= end) {
					const progress = (frame - start) / (end - start)

					content.style.opacity = 1
				} else {
					content.style.opacity = 0
				}
			})
		}

		if (animation) {
			// On initial page load - set frame immediately
			updateAnimationFrame()

			window.addEventListener('scroll', () => {
				updateAnimationFrame()

				const footerRect = footer.getBoundingClientRect()

				// When footer is about to appear
				if (footerRect.top <= window.innerHeight) {
					// Release animation from fixed
					lottieWrapper.classList.remove('fixed', 'inset-0')
					lottieWrapper.classList.add(
						'absolute',
						'bottom-0',
						'left-0',
						'right-0'
					)
				} else {
					// Stay fixed normally while scrolling
					lottieWrapper.classList.add('fixed', 'inset-0')
					lottieWrapper.classList.remove(
						'absolute',
						'bottom-0',
						'left-0',
						'right-0'
					)
				}
			})
		}
	}
</script>
