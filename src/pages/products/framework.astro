---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import HomeHero from '@components/home/HomeHero.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import { SITE } from '@config'
import FrameworkHero from '@components/products/framework-hero.astro'
import FrameworkFeatures from '@components/products/framework-features.astro'
import FrameworkIntegrateWorkflow from '@components/products/framework-integrate-workflow.astro'
import FrameworkIntegrateUi from '@components/products/framework-integrate-ui.astro'
---

<RootLayout
  title={`${SITE.title} - Framework`}
  description="Build seamless integrations, workflows and widgets - create your experience"
>
  <HeroContainer>
      <FrameworkHero />
      <Divider />
      <FrameworkFeatures />
      <Divider />
      <FrameworkIntegrateWorkflow />
      <Divider />
      <FrameworkIntegrateUi />
  </HeroContainer>
  <Divider />
  <Footer />
</RootLayout>
