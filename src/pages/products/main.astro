---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import { SITE } from '@config'
import FleetopsFeatures from '@components/products/fleetops-features.astro'
import StorefrontFeatures from '@components/products/storefront-features.astro'
import InventoryFeatures from '@components/products/inventory-features.astro'
import StorefrontAppFeatures from '@components/products/storefront-app-features.astro'
import DriverAppFeatures from '@components/products/driver-app-features.astro'
import CustomerPortalFeatures from '@components/products/customer-portal-features.astro'
---

<RootLayout
  title={`Products | ${SITE.title}`}
  description="Open source customer portal for logistics operations."
>
  <HeroContainer>
    <FleetopsFeatures />
    <StorefrontFeatures />
    <InventoryFeatures />
    <StorefrontAppFeatures />
    <DriverAppFeatures />
    <CustomerPortalFeatures />
  </HeroContainer>
  <Divider />
  <Footer />
</RootLayout>
