      </div>
    </div>
    <div class="mt-12 lg:col-span-4 lg:pl-10 xl:col-span-5 xl:pl-24">
      <div class="splide__track !overflow-visible">
        <ul class="splide__list list-none">
          {/* for each feature loop through the codeBlocks */}
