                      name={feature.icon}
                      class="h-[17px] w-[17px] text-blue-50 lg:h-4 lg:w-4 xl:h-[17px] xl:w-[17px]"
                    />
                    <h3 class="text-[17px] font-semibold text-white lg:text-base xl:text-[17px]">
                      {feature.title}
