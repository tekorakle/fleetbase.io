---
import Container from '@components/shared/Container.astro'
import Button from '@components/shared/Button.astro'
import { Image } from 'astro:assets'

import spaceSpotlight from '@images/space-spotlight.png'
---

<Container class="py-16 sm:py-20 lg:py-24">
  {/* Text content */}
  <div class="relative z-10 flex flex-col items-center">
    <h1
      class="max-w-5xl text-center text-4xl font-bold leading-extratight text-blue-100 sm:text-5xl sm:leading-tight"
    >
      Join the open source movement
      <br />
      Get started
      <span class="relative inline-block text-nowrap">
        <span
          class="relative z-10 bg-gradient-to-b from-blue-400 via-blue-400 to-blue-500 bg-clip-text text-transparent"
        >
          today.
        </span>
        <span class="absolute -top-px left-0 -z-10 text-blue-300">
          today.
        </span>
      </span>
    </h1>
    <p
      class="mt-5 max-w-xl text-center text-[17px] leading-8 text-zinc-200 sm:text-lg sm:leading-8"
    >
      Start managing orders for free using either our SAAS or Self Hosted
      versions of Fleetbase.
    </p>
    <div class="mt-8 flex items-center justify-center space-x-3 sm:space-x-5">
      <Button href="https://console.fleetbase.io"> Get started </Button>
      <Button href="https://cal.com/shivthakker/enquiry">
        Talk to an expert
      </Button>
    </div>
  </div>
</Container>

<Image
  src={spaceSpotlight}
  alt=""
  class="absolute -bottom-3/4 left-1/2 h-auto max-w-3xl -translate-x-1/2 object-contain opacity-90 sm:max-w-4xl md:-bottom-full lg:-bottom-[135%] lg:max-w-7xl"
/>
