---
import Container from '@components/shared/Container.astro'
import StarField from '@components/shared/StarField.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import orderImage from '@images/order-config.png'
import fleetImage from '@images/fleet-image-new.png'
import routeOptimization from '@images/route-optimization.png'
import serviceRates from '@images/service-rates.png'
import graphic from '@images/fleetops-console.png'
import cosmicButterfly from '@images/cosmic-butterfly.png'
import spaceSpotlight from '@images/space-spotlight.png'

const features = [
  {
    title: 'Fleet Management',
    summary: 'Gain complete oversight and control over your vehicles and drivers.',
    points: [
      'Track vehicle location and movement',
      'View driver assignment history',
      'Schedule preventive maintenance',
      'Keep documents and records in sync',
    ],
    tryNowLink: 'https://demo.fleetbase.io/fleet-management',
    exploreCodeLink: 'https://github.com/fleetbase/fleet-management-module',
    image: fleetImage,
  },
  {
    title: 'Order Configurations',
    summary: 'Tailor your logistics flow by customizing order behavior end-to-end.',
    points: [
      'Add custom fields to any order',
      'Define activity flow with status logic',
      'Trigger updates based on conditions',
      'Perfect for complex delivery models',
    ],
    image: orderImage,
  },
  {
    title: 'Dynamic Service Rates',
    summary: 'Configure rates based on location, distance, or weight.',
    points: [
      'Set base rates and surcharges',
      'Define zone-to-zone pricing',
      'Automate rate selection at order time',
      'Support for weight-based logic',
    ],
    image: serviceRates,
  },
  {
    title: 'Route Optimization',
    summary: 'Cut costs and time by optimizing pickups, drop-offs, and delivery sequences.',
    points: [
      'Use algorithms to find optimal paths',
      'Minimize idle time and fuel costs',
      'Support for multi-drop routes',
      'Integrated with Fleetbase Navigator',
    ],
    image: routeOptimization,
  },
  {
    title: 'Real-Time Notifications & Tracking',
    summary: 'Stay in the loop with full visibility into every delivery in motion.',
    points: [
      'Track all orders and vehicles live',
      'Enable push/email/SMS notifications',
      'Receive alerts for delays and changes',
      'Ensure transparency for all stakeholders',
    ],
  },
]
---

<section class="relative overflow-hidden">
  <Container class="pb-16 pt-20 sm:pb-20 sm:pt-24 lg:pb-32">
    {/* Header */}
    <div class="relative flex flex-col items-center text-center">
      <h1 class="max-w-5xl text-4xl font-bold leading-extratight text-blue-100 sm:text-5xl sm:leading-extratight">
        Open Source<br />
        <span class="relative inline-block text-nowrap">
          <span class="relative z-10 bg-gradient-to-b from-blue-400 via-blue-400 to-blue-500 bg-clip-text text-transparent">
            Dynamic TMS
          </span>
          <span class="absolute -top-px left-0 -z-10 text-blue-300">
            Dynamic TMS
          </span>
        </span>
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-8 text-zinc-200">
        Everything you need to manage your fleet, run logistics operations and gain insight into your data.
      </p>
    </div>

    {/* FleetOps Video Showcase */}
    <div class="mt-16 flex justify-center px-4 sm:px-6 lg:px-8" data-aos="zoom-in-up">
      <div class="relative w-full max-w-6xl overflow-hidden rounded-3xl border border-zinc-700/40 bg-zinc-900/40 backdrop-blur-sm shadow-[0_20px_80px_rgba(0,0,0,0.3)] transition-transform hover:scale-[1.02] duration-300 ease-in-out">
        <div class="aspect-video w-full">
          <iframe
            src="https://www.youtube.com/embed/_oAhj_uKWYk"
            title="FleetOps Demo"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full rounded-3xl"
          ></iframe>
        </div>
        <div class="absolute bottom-4 right-4 bg-blue-500 text-white text-xs uppercase tracking-wide px-3 py-1 rounded-full shadow-md">
          Demo
        </div>
      </div>
    </div>

    {/* Modern Feature Sections */}
    {features.map((feature, index) => {
      const isEven = index % 2 === 0
      return (
        <div
          class={`relative mt-32 flex flex-col gap-10 lg:gap-20 ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}
          data-aos="fade-up"
        >
          {/* Feature Image with Glow */}
          <div class="relative w-full lg:w-[65%]">
            <div class="absolute -inset-4 z-[-1] blur-2xl opacity-20 rounded-3xl bg-gradient-to-br from-blue-500 via-indigo-500 to-purple-600"></div>
            <div class="rounded-2xl overflow-hidden border border-blue-200/[.08] bg-white/[.02] shadow-2xl hover:shadow-blue-500/30 transition-all duration-300">
              <Image
                src={feature.image ?? graphic}
                alt={feature.title}
                widths={[1280, 1600, 1920]}
                sizes="(max-width: 768px) 100vw, 1280px"
                class="w-full h-auto"
              />
            </div>
          </div>

          {/* Feature Text Card */}
          <div class="w-full lg:w-[35%] flex flex-col justify-center text-white bg-white/5 rounded-2xl p-6 shadow-lg border border-white/10 backdrop-blur-md">
            <h3 class="text-2xl sm:text-3xl font-bold mb-4">{feature.title}</h3>
            <p class="text-base text-zinc-300 mb-4">{feature.summary}</p>

            <ul class="space-y-2 list-disc list-inside text-zinc-200 text-sm sm:text-base mb-6">
              {feature.points.map(point => (
                <li>{point}</li>
              ))}
            </ul>

            <div class="flex flex-col sm:flex-row justify-start gap-4">
              <a
              href="https://console.fleetbase.io/auth"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-blue-500 hover:bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-md transition-all"
            >
              <Icon name="heroicons:rocket-launch-solid" class="h-4 w-4" />
              Try Now
            </a>

              <a
                href="https://github.com/fleetbase/fleetops"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-white px-5 py-2 text-sm font-semibold text-white hover:bg-white hover:text-black transition-all"
              >
                <Icon name="heroicons:code-bracket-square" class="h-4 w-4" />
                Explore Code
              </a>
            </div>
          </div>
        </div>
      )
    })}
  </Container>
</section>