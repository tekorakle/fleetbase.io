---
import Container from '@components/shared/Container.astro'
import StarField from '@components/shared/StarField.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

import graphic from '@images/storefront-console.png'
import cosmicButterfly from '@images/cosmic-butterfly.png'
import spaceSpotlight from '@images/space-spotlight.png'

const features = [
  {
    icon: 'heroicons:cursor-arrow-ripple-solid',
    title: 'Headless E-Commerce',
    description:
      'Storefront is a headless e-commerce service integrated with Fleetbase, offering developers API-first control over products, carts, categories, customers, and checkout flows.',
  },
  {
    icon: 'heroicons:presentation-chart-line-solid',
    title: 'Customizable Shopping Experience',
    description:
      'Built as an open-source hyperlocal shopping app, Storefront is fully customizable and can be adapted for personal or commercial projects, giving complete freedom over the user experience.',
  },
  {
    icon: 'heroicons:shield-check-solid',
    title: 'Mobile App Built with React Native',
    description:
      'The mobile version of Storefront, developed with React Native, provides a robust starting point for React Native developers to create tailored e-commerce solutions.',
  },
  {
    icon: 'heroicons:chat-bubble-left-right-solid',
    title: 'Web Application',
    description:
      'Access Storefront through its web version, providing a seamless shopping experience and management capabilities for stores and customers.',
  },
  {
    icon: 'heroicons:sparkles-solid',
    title: 'Order & Customer Management',
    description:
      'The Storefront dashboard offers tools to manage all orders, customers, and stores efficiently, alongside insights into your current earnings.',
  },
  {
    icon: 'heroicons:chart-pie-solid',
    title: 'Earnings Dashboard',
    description:
      'Track revenue and earnings in real-time with intuitive analytics to monitor your e-commerce success.',
  },
  {
    icon: 'heroicons:sparkles-solid',
    title: 'Hyperlocal Focus',
    description:
      'Ideal for hyperlocal shopping experiences, enabling businesses to cater to localized audiences with tailored services.',
  },
  {
    icon: 'heroicons:cursor-arrow-ripple-solid',
    title: 'API-First Integration',
    description:
      'Storefront’s API-driven design allows seamless integration with other Fleetbase services, ensuring a unified ecosystem for logistics and e-commerce.',
  },
  {
    icon: 'heroicons:sparkles-solid',
    title: 'Custom Checkout Flows',
    description:
      'Design personalized checkout experiences with API control, enhancing the shopping journey and increasing customer satisfaction.',
  },
  {
    icon: 'heroicons:shield-check-solid',
    title: 'Developer-Friendly Architecture',
    description:
      'Built with extensibility in mind, Storefront empowers developers with tools to quickly build and deploy scalable e-commerce solutions.',
  },
  {
    icon: 'heroicons:chat-bubble-left-right-solid',
    title: 'Real-Time Updates',
    description:
      'Keep customers and store managers updated with real-time order statuses, notifications, and more.',
  },
  {
    icon: 'heroicons:sparkles-solid',
    title: 'Category & Product Management',
    description:
      'Organize and manage your inventory efficiently with robust tools for product and category management.',
  },
]
---

<section class="relative overflow-hidden">
  <Container class="pb-16 pt-20 sm:pb-20 sm:pt-24 lg:pb-24">
    {/* Text content */}
    <div class="relative flex flex-col items-center">
      <h1
        class="max-w-5xl text-center text-4xl font-bold leading-extratight text-blue-100 sm:text-5xl sm:leading-extratight"
      >
        Open Source <br />
        <span class="relative inline-block text-nowrap">
          <span
            class="relative z-10 bg-gradient-to-b from-blue-400 via-blue-400 to-blue-500 bg-clip-text text-transparent"
          >
            E-commerce Mobile & Web App
          </span>
          <span class="absolute -top-px left-0 -z-10 text-blue-300"
            >E-commerce Mobile & Web App</span
          >
        </span>
      </h1>
      <p class="mt-5 max-w-xl text-center text-lg leading-8 text-zinc-200">
        Storefront is a headless e-commerce service which functions as an
        extension within Fleetbase.
      </p>
    </div>

    {/* Graphic */}
    <div
      class="relative mt-10 w-full rounded-xl border border-blue-200/[.08] bg-white/[.01] p-1 shadow-inner-blur sm:mt-16 sm:rounded-2xl sm:p-2 lg:mt-18"
    >
      <div
        class="absolute -left-56 -right-56 -top-80 -z-10 sm:-left-48 sm:-right-48 md:left-1/2 md:w-full md:max-w-6xl md:-translate-x-1/2 lg:-top-96"
      >
        <Image
          src={spaceSpotlight}
          alt=""
          widths={[420, 768, 1152]}
          sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (min-width: 768px) 1152px`}
          class="h-full w-full object-contain"
        />
      </div>
      {/* Stars */}
      <div
        class="absolute -top-48 left-1/2 -z-10 h-56 w-full max-w-3xl -translate-x-1/2"
        aria-hidden="true"
      >
        <StarField density="medium" maxRadius={2.25} />
      </div>
      <div class="absolute -bottom-96 -left-96 -right-96 top-0 -z-10">
        <Image
          src={cosmicButterfly}
          alt=""
          class="h-full w-full object-contain opacity-10"
          widths={[420, 768, 1024]}
          sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, (min-width: 1024px) 1024px`}
        />
      </div>

      <Image
        src={graphic}
        alt="Collaboration interface with user profile images"
        widths={[420, 768, 1024, graphic.width]}
        sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, (min-width: 1024px) ${graphic.width}px`}
        class="relative h-auto w-full rounded-lg"
      />
    </div>

    {/* Features */}
    <div
      class="relative mx-auto mt-10 grid max-w-lg grid-cols-1 gap-x-6 gap-y-5 sm:mt-16 sm:max-w-2xl sm:grid-cols-2 sm:gap-y-9 md:mt-18 lg:mx-0 lg:max-w-none lg:grid-cols-3"
    >
      {
        features.map((feature) => (
          <div>
            <Icon
              name={feature.icon}
              class="-mt-0.5 mr-1.5 inline h-5 w-5 shrink-0 text-blue-400 sm:h-[21px] sm:w-[21px]"
            />
            <p class="inline text-[17px] leading-7 text-zinc-300 md:text-lg md:leading-8">
              <span class="font-semibold text-white">{feature.title}</span>{' '}
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
