---
import Container from '@components/shared/Container.astro'
import { Image } from 'astro:assets'
import graphic from '@images/screenshots/storefront-screenshot-edit-product.png'
---

<section class="relative overflow-hidden bg-zinc-950">
	<Container class="pt-24 pb-20 sm:pt-28 sm:pb-24">
		<div class="flex flex-col-reverse items-center justify-between gap-12 lg:flex-row">
			<div class="w-full max-w-2xl text-left">
				<h1 class="text-4xl font-bold leading-tight text-blue-100 sm:text-5xl">
					Deliver commerce with precision,<br />
					<span class="relative inline-block">
						<span class="z-10 bg-gradient-to-b from-blue-400 to-blue-500 bg-clip-text text-transparent">
							from checkout to doorstep.
						</span>
						<span class="absolute -top-px left-0 -z-10 text-blue-300 opacity-10">
							from checkout to doorstep.
						</span>
					</span>
				</h1>
				<p class="mt-6 text-lg leading-8 text-zinc-300">
					Storefront by Fleetbase is the logistics-first, headless ecommerce platform that powers hyperlocal commerce — perfect for restaurants, corner shops, and any business delivering locally.
				</p>
			</div>

			<div class="w-full max-w-3xl">
                <div class="h-[620px] w-full overflow-hidden rounded-xl border border-gray-800 bg-zinc-900 shadow-xl p-2">
                    <!-- Background image div -->
                    <div
                        class="h-full w-full rounded-lg border border-gray-800 bg-no-repeat bg-cover bg-left-top"
                        style={`background-image: url(${graphic.src}); background-size: ${graphic.width/2.7}px ${graphic.height/2.7}px;`}
                    ></div>
                </div>
            </div>
		</div>
	</Container>
</section>