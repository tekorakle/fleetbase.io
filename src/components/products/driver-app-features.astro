---
import Container from '@components/shared/Container.astro'
import StarField from '@components/shared/StarField.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import navigatorImage from '@images/navigator.png'
import trackingImage from '@images/route-optimization.png'
import podImage from '@images/order-config.png'
import chatImage from '@images/service-rates.png'

const features = [
  {
    title: 'Live Tracking & Order Overview',
    summary: 'Get a real-time view of your driver’s location, status, and activity.',
    points: [
      'Live GPS tracking with coordinate visibility',
      'Online / Offline driver status',
      'Current speed display and trip duration',
      'Overview of active and assigned orders',
    ],
    image: navigatorImage,
  },
  {
    title: 'Order Calendar & Proof of Delivery',
    summary: 'View all orders in a calendar or list format, complete deliveries with built-in tools.',
    points: [
      'Full calendar view of all orders',
      'Detailed view of each order including stops and instructions',
      'Mark orders as completed with QR scan, e-signature, or manual update',
      'Live sync of status updates with dispatcher console',
    ],
    image: podImage,
  },
  {
    title: 'Issue & Fuel Reporting',
    summary: 'Allow drivers to log real-time issues and submit operational reports on the go.',
    points: [
      'In-app issue tracker for reporting delivery or vehicle problems',
      'Fuel usage reporting by location and date',
      'Optional photo attachment for transparency',
      'Automatic dispatch notification on report submission',
    ],
    image: trackingImage,
  },
  {
    title: 'Instant Communication',
    summary: 'Stay connected with your drivers in real-time from anywhere.',
    points: [
      'Integrated chat module in the app',
      'Supports WhatsApp, Telegram, and internal chat',
      'Instant message sync with logistics team',
      'Optional read receipts and message history',
    ],
    image: chatImage,
  },
  {
    title: 'Driver Profile & Account Management',
    summary: 'Give drivers control over their personal and operational information.',
    points: [
      'Profile management and basic settings',
      'View performance history and logs',
      'Manage app preferences and language settings',
      'Supports profile photo and contact updates',
    ],
    image: navigatorImage,
  },
  {
    title: 'Push Notifications',
    summary: 'Never miss a beat with live alerts and real-time updates.',
    points: [
      'Receive alerts for new tasks or reassigned deliveries',
      'Delivery delay notifications',
      'Automatic reminders for pending tasks',
      'Custom push rules via Fleetbase Console',
    ],
    image: navigatorImage
  },
]
---

<section class="relative overflow-hidden">
  <Container class="pb-16 pt-20 sm:pb-20 sm:pt-24 lg:pb-32">
    <!-- Demo Video -->
    <div class="mt-16 flex justify-center px-4 sm:px-6 lg:px-8" data-aos="zoom-in-up">
      <div class="relative w-full max-w-6xl overflow-hidden rounded-3xl border border-zinc-700/40 bg-zinc-900/40 backdrop-blur-sm shadow-[0_20px_80px_rgba(0,0,0,0.3)] transition-transform hover:scale-[1.02] duration-300 ease-in-out">
        <div class="aspect-video w-full">
          <iframe
            src="https://www.youtube.com/embed/_oAhj_uKWYk"
            title="Fleetbase Navigator Demo"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full rounded-3xl"
          ></iframe>
        </div>
        <div class="absolute bottom-4 right-4 bg-blue-500 text-white text-xs uppercase tracking-wide px-3 py-1 rounded-full shadow-md">
          Demo
        </div>
      </div>
    </div>

    <!-- Feature Sections -->
    {features.map((feature, index) => {
      const isEven = index % 2 === 0
      return (
        <div
          class={`relative mt-32 flex flex-col gap-10 lg:gap-20 ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}
          data-aos="fade-up"
        >
          <!-- Feature Image -->
          <div class="relative w-full lg:w-[65%]">
            <div class="absolute -inset-4 z-[-1] blur-2xl opacity-20 rounded-3xl bg-gradient-to-br from-blue-500 via-indigo-500 to-purple-600"></div>
            <div class="rounded-2xl overflow-hidden border border-blue-200/[.08] bg-white/[.02] shadow-2xl hover:shadow-blue-500/30 transition-all duration-300">
              <Image
                src={feature.image}
                alt={feature.title}
                widths={[1280, 1600, 1920]}
                sizes="(max-width: 768px) 100vw, 1280px"
                class="w-full h-auto"
              />
            </div>
          </div>

          <!-- Feature Text -->
          <div class="w-full lg:w-[35%] flex flex-col justify-center text-white bg-white/5 rounded-2xl p-6 shadow-lg border border-white/10 backdrop-blur-md">
            <h3 class="text-2xl sm:text-3xl font-bold mb-4">{feature.title}</h3>
            <p class="text-base text-zinc-300 mb-4">{feature.summary}</p>
            <ul class="space-y-2 list-disc list-inside text-zinc-200 text-sm sm:text-base mb-6">
              {feature.points.map(point => (
                <li>{point}</li>
              ))}
            </ul>
            <div class="flex flex-col sm:flex-row justify-start gap-4">
              <a
                href="https://console.fleetbase.io/auth"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full bg-blue-500 hover:bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-md transition-all"
              >
                <Icon name="heroicons:rocket-launch-solid" class="h-4 w-4" />
                Try Now
              </a>
              <a
                href="https://github.com/fleetbase/navigator"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-white px-5 py-2 text-sm font-semibold text-white hover:bg-white hover:text-black transition-all"
              >
                <Icon name="heroicons:code-bracket-square" class="h-4 w-4" />
                Explore Code
              </a>
            </div>
          </div>
        </div>
      )
    })}
  </Container>
</section>