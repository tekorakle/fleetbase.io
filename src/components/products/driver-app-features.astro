---
import Container from '@components/shared/Container.astro'
import StarField from '@components/shared/StarField.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

import graphic from '@images/navigator2.png'
import cosmicButterfly from '@images/cosmic-butterfly.png'
import spaceSpotlight from '@images/space-spotlight.png'

const features = [
  {
    icon: 'heroicons:cursor-arrow-ripple-solid',
    title: 'Open Source & Fully Customizable',
    description:
      'Fleetbase Navigator is an open-source navigation and order management app for drivers and agents, fully customizable to meet your specific operational needs.',
  },
  {
    icon: 'heroicons:qr-code-solid',
    title: 'QR Code Scanning',
    description:
      'Supports QR code scanning for seamless proof of delivery and order verification.',
  },
  {
    icon: 'heroicons:pencil-square-solid',
    title: 'Digital Signatures',
    description:
      'Enables digital signature capture for secure and verifiable order completion.',
  },
  {
    icon: 'heroicons:map-solid',
    title: 'Routing & Navigation',
    description:
      'Provides efficient routing and turn-by-turn navigation for drivers and agents to optimize their journeys.',
  },
  {
    icon: 'heroicons:clock-solid',
    title: 'Schedule View',
    description:
      'Offers a detailed schedule view to help drivers manage and organize their tasks for the day.',
  },
  {
    icon: 'heroicons:check-circle-solid',
    title: 'Activity Updates',
    description:
      'Allows drivers to update order activities in real-time as they complete jobs.',
  },
  {
    icon: 'heroicons:currency-dollar-solid',
    title: 'Wallet Management',
    description:
      'Drivers can manage their wallet, view earnings, and track payments directly within the app.',
  },
  {
    icon: 'heroicons:user-circle-solid',
    title: 'Driver Earnings Overview',
    description:
      'Provides insights into daily, weekly, or monthly earnings to help drivers track their income.',
  },
  {
    icon: 'heroicons:shield-check-solid',
    title: 'Secure & Reliable',
    description:
      'Designed for reliability and security, ensuring smooth operations and data integrity for drivers and agents.',
  },
  {
    icon: 'heroicons:chat-bubble-left-right-solid',
    title: 'Real-Time Updates',
    description:
      'Syncs with the Fleetbase ecosystem in real-time, keeping orders, schedules, and activities up to date.',
  },
  {
    icon: 'heroicons:sparkles-solid',
    title: 'Cross-Platform Support',
    description:
      'Available on both iOS and Android, providing accessibility for drivers across multiple platforms.',
  },
]
---

<section class="relative overflow-hidden">
  <Container class="pb-16 pt-20 sm:pb-20 sm:pt-24 lg:pb-24">
    {/* Text content */}
    <div class="relative flex flex-col items-center">
      <h1
        class="max-w-5xl text-center text-4xl font-bold leading-extratight text-blue-100 sm:text-5xl sm:leading-extratight"
      >
        Open Source<br />
        <span class="relative inline-block text-nowrap">
          <span
            class="relative z-10 bg-gradient-to-b from-blue-400 via-blue-400 to-blue-500 bg-clip-text text-transparent"
          >
            Driver Mobile App
          </span>
          <span class="absolute -top-px left-0 -z-10 text-blue-300"
            >Driver Mobile App</span
          >
        </span>
      </h1>
      <p class="mt-5 max-w-xl text-center text-lg leading-8 text-zinc-200">
        Open source mobile app for drivers to manage, update and submit updates
        for delivery orders.
      </p>
    </div>

    {/* Graphic */}
    <div
      class="relative mt-10 w-full rounded-xl border border-blue-200/[.08] bg-white/[.01] p-1 shadow-inner-blur sm:mt-16 sm:rounded-2xl sm:p-2 lg:mt-18"
    >
      <div
        class="absolute -left-56 -right-56 -top-80 -z-10 sm:-left-48 sm:-right-48 md:left-1/2 md:w-full md:max-w-6xl md:-translate-x-1/2 lg:-top-96"
      >
        <Image
          src={spaceSpotlight}
          alt=""
          widths={[420, 768, 1152]}
          sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (min-width: 768px) 1152px`}
          class="h-full w-full object-contain"
        />
      </div>
      {/* Stars */}
      <div
        class="absolute -top-48 left-1/2 -z-10 h-56 w-full max-w-3xl -translate-x-1/2"
        aria-hidden="true"
      >
        <StarField density="medium" maxRadius={2.25} />
      </div>
      <div class="absolute -bottom-96 -left-96 -right-96 top-0 -z-10">
        <Image
          src={cosmicButterfly}
          alt=""
          class="h-full w-full object-contain opacity-10"
          widths={[420, 768, 1024]}
          sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, (min-width: 1024px) 1024px`}
        />
      </div>

      <Image
        src={graphic}
        alt="Collaboration interface with user profile images"
        widths={[420, 768, 1024, graphic.width]}
        sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, (min-width: 1024px) ${graphic.width}px`}
        class="relative h-auto w-full rounded-lg"
      />
    </div>

    {/* Features */}
    <div
      class="relative mx-auto mt-10 grid max-w-lg grid-cols-1 gap-x-6 gap-y-5 sm:mt-16 sm:max-w-2xl sm:grid-cols-2 sm:gap-y-9 md:mt-18 lg:mx-0 lg:max-w-none lg:grid-cols-3"
    >
      {
        features.map((feature) => (
          <div>
            <Icon
              name={feature.icon}
              class="-mt-0.5 mr-1.5 inline h-5 w-5 shrink-0 text-blue-400 sm:h-[21px] sm:w-[21px]"
            />
            <p class="inline text-[17px] leading-7 text-zinc-300 md:text-lg md:leading-8">
              <span class="font-semibold text-white">{feature.title}</span>{' '}
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
