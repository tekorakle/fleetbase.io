---
import Container from '@components/shared/Container.astro'
import StarField from '@components/shared/StarField.astro'
import InvestorTestimonials from './InvestorTestimonials.astro'
import PricingCard from './PricingCard.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import cosmicButterfly from '@images/cosmic-butterfly.png'

const pricingPlans = [
  {
    title: 'Self Hosted',
    price: { monthly: '$0', annually: '$0' },
    description: 'Run Fleetbase locally with full control and no fees.',
    features: [
      { label: 'Self-hosted freedom', description: 'Deploy on your infrastructure with no recurring costs.' },
      { label: 'Community support', description: 'Get help through Fleetbase forums and GitHub.' },
      { label: 'Open-source license', description: 'Use under AGPL with complete transparency.' },
      { label: 'Docker-ready', description: 'Spin up your own instance in minutes using our Docker setup.' },

    ],
    cta: { label: 'View on GitHub', url: 'https://github.com/fleetbase/fleetbase' },
    popular: false,
  },
  {
    title: 'Cloud Plan',
    price: { monthly: '$200', annually: '$2200' },
    description: 'Fully managed cloud hosting with unlimited users.',
    features: [
      { label: 'Unlimited users & drivers', description: 'Scale without any usage caps.' },
      { label: 'Managed hosting', description: 'Hosted by Fleetbase on secure cloud infrastructure.' },
      { label: 'Premium support', description: 'Fast-track help from the Fleetbase team.' },
      { label: 'Custom order flows', description: 'Configure unique workflows for courier, freight, on-demand, B2B, and marketplace operations.' },

    ],
    cta: { label: 'Start Free Trial', url: 'https://console.fleetbase.io/auth' },
    popular: true,
  },
  {
    title: 'Fully Deployed',
    price: { monthly: '$2500', annually: '$2500' },
    description: 'Deployed on your infrastructure — fully configured and branded.',
    features: [
      { label: 'Custom deployment', description: 'Tailored setup on AWS, GCP, DigitalOcean, or on-prem.' },
      { label: 'Branded environment', description: 'Includes white-labeling and domain configuration.' },
      { label: 'Training & testing', description: 'Hands-on product training and validation prior to launch.' },
      { label: 'Optional support plans', description: 'Ongoing maintenance and upgrades available post-deployment.' },
    ],
    cta: { label: 'Implement Now', url: 'https://tally.so/r/mVbv2M' },
    popular: false,
  }
]
---

<div class="pb-12 pt-20 md:pb-20 lg:py-28">
  <div class="relative">
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      <StarField />
    </div>

    <Container class="max-w-4xl gap-16 lg:max-w-screen-xl" x-data="{ billingType: 'monthly' }">
      <div class="relative z-10 flex flex-col items-center">
        <div class="flex items-center rounded-full bg-zinc-950/[.01] shadow-inner-blur">
          <div class="flex items-center space-x-2 rounded-full border border-violet-200/[.06] px-4 py-1.5">
            <Icon name="nucleo/tags-stack-16" class="h-3.5 w-3.5 text-violet-200" />
            <span class="text-sm font-medium text-violet-100 drop-shadow-[-12px_-4px_6px_rgba(237,233,254,0.2)]">
              Fleetbase' pricing
            </span>
          </div>
        </div>
        <h1 class="mt-5 text-center text-[2.75rem] font-bold leading-[1.125] text-violet-100 sm:text-5xl md:text-6xl lg:text-[64px]">
          Transparent Cloud &<br />Open Source Pricing
        </h1>
      </div>

      <div class="mx-auto mt-12 flex max-w-lg flex-col items-center lg:mx-0 lg:mt-20 lg:max-w-none">
        <div class="flex items-center rounded-full bg-zinc-950/[.01] shadow-inner-blur">
          <div class="flex items-center space-x-2 rounded-full border border-violet-200/[.06] px-1 py-1">
            <button
              @click="billingType = 'monthly'"
              class="group relative inline-flex items-center rounded-full px-4 py-2 text-sm font-semibold"
              :class="billingType === 'monthly' ? 'bg-btn-primary text-white shadow-btn-primary' : 'text-violet-50 hover:text-white'"
            >Monthly</button>
            <button
              @click="billingType = 'annual'"
              class="group relative inline-flex items-center rounded-full px-4 py-2 text-sm font-semibold"
              :class="billingType === 'annual' ? 'bg-btn-primary text-white shadow-btn-primary' : 'text-violet-50 hover:text-white'"
            >Annually</button>
          </div>
        </div>

        <div class="relative w-full mt-10">
          <div class="absolute -bottom-64 -left-96 -right-96 top-0 -z-10">
            <Image
              src={cosmicButterfly}
              alt=""
              class="h-full w-full object-fill opacity-10"
              widths={[420, 768, 1024]}
              sizes="(max-width: 1024px) 100vw, 1024px"
            />
          </div>
          <div class="grid w-full gap-8 lg:grid-cols-3 xl:gap-12">
            {
              pricingPlans.map((plan) => (
                <div class="flex flex-col justify-between rounded-2xl border border-zinc-800 bg-zinc-900/50 p-6 shadow-lg">
                  <PricingCard plan={plan} />
                  <div class="mt-6 space-y-4">
                    {plan.features.map((feature) => (
                      <div class="flex items-start space-x-3">
                        <Icon name="nucleo/o-check-16" class:list={['mt-1.5 h-4 w-4 shrink-0', plan.popular ? 'text-violet-400' : 'text-white']} />
                        <p class="text-sm text-zinc-300">
                          <span class="font-semibold text-white">{feature.label}.</span> {feature.description}
                        </p>
                      </div>
                    ))}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </Container>
  </div>

  <InvestorTestimonials />

  <section class="mt-24 max-w-4xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-white text-center mb-8">Custom License</h2>
    <div class="space-y-6">
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6 shadow-md">
        <h3 class="text-xl font-semibold text-white mb-2">What if I need a custom license?</h3>
        <p class="text-zinc-300 leading-relaxed">
          If you're an enterprise or third-party provider that needs to modify, rebrand, or commercially offer Fleetbase as a service without complying with the AGPL license, you can request a custom commercial license. This gives you full legal clearance to use Fleetbase as part of your proprietary offering while supporting the sustainability of open source innovation.
        </p>
        <a
          href="https://cal.com/shivthakker/enquiry"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center text-sm font-semibold text-blue-400 hover:text-blue-300"
        >
          Request a custom license
          <Icon name="heroicons:arrow-right-16-solid" class="ml-2 h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

</div>