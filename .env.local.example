# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored; this example file is committed.

# ── PostHog (product analytics) ───────────────────────────────────────────────
# Required for analytics on every environment. Calls no-op if unset.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Ghost CMS (blog) ──────────────────────────────────────────────────────────
# Required for /blog routes. Without these, blog pages render an empty state.
GHOST_API_URL=
GHOST_CONTENT_API_KEY=
GHOST_API_VERSION=v5.0

# ── API docs generator (advanced) ─────────────────────────────────────────────
# Override the path the generator reads collections from. Defaults to
# vendor/postman/postman/collections — only set if you point at a custom path.
# POSTMAN_COLLECTIONS_DIR=
