# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored; this example file is committed.

# ── PostHog (product analytics) ───────────────────────────────────────────────
# Required for analytics on every environment. Calls no-op if unset.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Google Analytics 4 (SEO + Google Ads attribution) ─────────────────────────
# GA4 Measurement ID (G-XXXXXXXXXX). Mirrors only conversion events from the
# PostHog event taxonomy; not a replacement for PostHog. No-op if unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Ahrefs Web Analytics (SEO cross-reference) ────────────────────────────────
# Ahrefs project key from analytics.ahrefs.com. Cookieless and GDPR-compliant
# by default — runs identically for all visitors. No-op if unset.
NEXT_PUBLIC_AHREFS_KEY=

# ── Ghost CMS (blog) ──────────────────────────────────────────────────────────
# Required for /blog routes. Without these, blog pages render an empty state.
GHOST_API_URL=
GHOST_CONTENT_API_KEY=
GHOST_API_VERSION=v5.0

# ── SEO content agent (GitHub Actions / local dry-runs) ───────────────────────
# The agent creates Ghost drafts only. Humans review, schedule, and publish in
# Ghost. CREATE_GHOST_DRAFT must be true before the Admin API is called.
AHREFS_API_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1.5
GHOST_ADMIN_API_URL=
GHOST_ADMIN_API_KEY=
CREATE_GHOST_DRAFT=false
GENERATE_FEATURE_IMAGE=true
GENERATE_FEATURE_IMAGE_IN_DRY_RUN=false
# CONTENT_AGENT_NOTIFY_WEBHOOK_URL=

# ── API docs generator (advanced) ─────────────────────────────────────────────
# Override the path the generator reads collections from. Defaults to
# vendor/postman/postman/collections — only set if you point at a custom path.
# POSTMAN_COLLECTIONS_DIR=
