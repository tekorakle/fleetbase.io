{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@animations/*": [
        "animations/*"
      ],
      "@components/*": [
        "components/*"
      ],
      "@layouts/*": [
        "layouts/*"
      ],
      "@pages/*": [
        "pages/*"
      ],
      "@images/*": [
        "images/*"
      ],
      "@styles/*": [
        "styles/*"
      ],
      "@scripts/*": [
        "scripts/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@config": [
        "config.ts"
      ],
      "@types": [
        "types.ts"
      ]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}