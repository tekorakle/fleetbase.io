---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import HomeHero from '@components/home/HomeHero.astro'
import BentoGridSection from '@components/home/BentoGridSection.astro'
import CodeSnippets from '@components/home/CodeSnippets.astro'
import Integrations from '@components/home/Integrations.astro'
import StorefrontAppFeatures from '@components/products/storefront-app-features.astro'
import Testimonials from '@components/home/Testimonials.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import { SITE } from '@config'
---

<RootLayout
  title={`Storefront App | ${SITE.title}`}
  description="Open source on demand delivery and services mobile app"
>
  <HeroContainer>
    <StorefrontAppFeatures />
  </HeroContainer>
  <Divider />
  <Footer />
</RootLayout>
