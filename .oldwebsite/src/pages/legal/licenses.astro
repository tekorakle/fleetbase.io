---
import RootLayout from '@layouts/RootLayout.astro'
import HeroContainer from '@components/shared/HeroContainer.astro'
import LicenseFaq from '@components/legal/license-faq.astro'
import LicenseLinks from '@components/legal/license-links.astro'
import Faq from '@components/shared/Faq.astro'
import Footer from '@components/shared/Footer.astro'
import Divider from '@components/shared/Divider.astro'
import { SITE } from '@config'
---

<RootLayout
  title={`Licenses | ${SITE.title}`}
  description="Nebula offers scalable pricing plans to suit your remote work requirements. Choose the plan that fits your team best."
>
  <HeroContainer
    starField={false}
    bgGradientClassName="opacity-60 lg:opacity-90 xl:opacity-100"
  />
  <Divider />
  <LicenseLinks />
  <Divider />
  <LicenseFaq />
  <Divider />
  <Footer />
</RootLayout>
