---
import Container from '@components/shared/Container.astro'
import StarField from '@components/shared/StarField.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

import spaceSpotlight from '@images/space-spotlight.png'
import cosmicButterfly from '@images/cosmic-butterfly.png'

const links = [
  {
    title: 'AGPL License',
    description:
      'Ensures Fleetbase remains open-source; public modifications must be shared',
    descriptionMobile: 'AGPL License Description.',
    url: 'https://discord.gg/HnTqQ6zAVn',
    icon: 'nucleo/company-18',
    label: 'Learn More',
    borderClassName:
      'after:inset-x-0 after:bottom-0 after:h-px after:w-full after:bg-gradient-to-r after:from-violet-200/[0.025] sm:after:from-transparent after:to-violet-200/[0.075] sm:after:to-violet-200/[0.125]',
  },
  {
    title: 'Custom License',
    description:
      'Allows proprietary use without sharing modifications with yearly fee.',
    descriptionMobile: 'Custom license descriptions.',
    url: 'https://github.com/fleetbase/fleetbase',
    icon: 'nucleo/magic-wand-16',
    label: 'Contact Us',
    borderClassName:
      'after:inset-x-0 after:bottom-0 after:h-px after:w-full after:bg-gradient-to-r after:from-violet-200/[0.075] after:to-violet-200/[0.15] sm:after:via-violet-200/[0.25] sm:after:to-violet-200/[0.125] sm:before:content-[""] sm:before:absolute sm:before:left-0 sm:before:h-full sm:before:w-px sm:before:bg-gradient-to-b sm:before:from-violet-200/[.01] sm:before:to-violet-200/[0.125]',
  },
]
---

<section class="relative overflow-x-clip">
  <div
    class="absolute -left-56 -right-56 -top-80 sm:-left-48 sm:-right-48 md:left-1/2 md:w-full md:max-w-6xl md:-translate-x-1/2 lg:-top-32"
  >
    <Image
      src={spaceSpotlight}
      alt=""
      class="h-full w-full object-contain opacity-25"
      widths={[420, 768, 1152]}
      sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (min-width: 768px) 1152px`}
    />
  </div>

  <Container
    class="relative max-w-lg gap-16 pb-16 pt-20 sm:max-w-screen-xl sm:pb-20 sm:pt-24 lg:pb-24"
  >
    <div class="absolute -left-96 -right-96 -top-48 bottom-0 -z-10">
      <Image
        src={cosmicButterfly}
        alt=""
        class="h-[calc(100%_+_336px)] w-[calc(100%_+_768px)] opacity-10"
        widths={[420, 768, 1024]}
        sizes={`(max-width: 420px) 420px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, (min-width: 1024px) 1024px`}
      />
    </div>

    {/* Text content */}
    <div class="flex flex-col items-center">
      <div
        class="flex items-center rounded-full bg-zinc-950/[.01] shadow-inner-blur"
      >
        <div
          class="flex h-full w-full items-center space-x-2 rounded-full border border-violet-200/[.06] px-4 py-1.5"
        >
          <Icon name="nucleo/link-16" class="h-3.5 w-3.5 text-violet-200" />
          <span
            class="text-sm font-medium text-violet-100 drop-shadow-[-12px_-4px_6px_rgba(237,233,254,0.2)]"
          >
            Licenses
          </span>
        </div>
      </div>

      <h1
        class="mt-5 max-w-5xl text-center text-4xl font-bold leading-extratight text-violet-100 sm:mt-6 sm:text-5xl sm:leading-extratight"
      >
        Fleetbase Open Source Licenses
      </h1>
      <p
        class="mt-5 max-w-2xl text-center text-[17px] leading-8 text-zinc-200 sm:text-lg sm:leading-8"
      >
      </p>
    </div>

    {/* Popular links */}
    <div class="relative mt-8 flex flex-wrap items-stretch justify-center">
      {
        links.map((link) => (
          <div
            class:list={[
              "group relative w-full bg-gradient-to-b after:absolute after:content-[''] sm:w-1/3",
              link.borderClassName,
            ]}
          >
            <div class="relative h-full w-full overflow-hidden">
              <div
                class="absolute bottom-1/3 left-1/3 right-0 top-0 opacity-0 duration-300 ease-in-out group-hover:opacity-100"
                aria-hidden="true"
              >
                <StarField density="high" maxRadius={1.75} minRadius={1} />
              </div>
              <div class="absolute inset-0 -z-10 bg-gradient-to-b from-[#575EFF]/10 to-[#E478FF]/10 opacity-0 blur-4xl duration-300 ease-in-out group-hover:opacity-100" />
              <div class="relative z-10 flex h-full w-full flex-1 flex-col justify-between px-4 py-5 sm:px-5 sm:py-6 lg:py-7 xl:p-8">
                <div class="flex-1">
                  <Icon
                    name={link.icon}
                    class="h-6 w-6 text-violet-50 sm:h-7 sm:w-7 xl:h-8 xl:w-8"
                  />

                  <h4 class="mt-5 text-base font-semibold text-violet-50 xl:mt-6 xl:text-lg">
                    {link.title}
                  </h4>
                  <p class="mt-2.5 line-clamp-3 text-base text-zinc-300 xl:text-lg">
                    <span class="sm:hidden">{link.descriptionMobile}</span>
                    <span class="hidden sm:inline">{link.description}</span>
                  </p>
                </div>
                <div class="mt-4 xl:mt-5">
                  <a
                    href={link.url}
                    class="flex items-center text-sm font-medium text-violet-300/70 duration-200 ease-in-out group-hover:text-violet-300 xl:text-base"
                  >
                    <span class="absolute inset-0" />
                    {link.label}
                    <Icon
                      name="nucleo/arrow-top-right-16"
                      class="ml-2.5 h-2.5 w-2.5 xl:h-3 xl:w-3"
                    />
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
