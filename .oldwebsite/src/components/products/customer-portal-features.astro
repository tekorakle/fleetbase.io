---
import Container from '@components/shared/Container.astro'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import customerPortalImage from '@images/customer-portal.png'
import trackingImage from '@images/route-optimization.png'
import paymentImage from '@images/service-rates.png'
import dashboardImage from '@images/fleetops-console.png'
import brandingImage from '@images/cosmic-butterfly.png'
import secureImage from '@images/order-config.png'

const features = [
  {
    title: 'Order Creation',
    summary: 'Enable customers to create and manage orders with ease.',
    points: [
      'Simple, intuitive order creation flow',
      'Upload supporting documents or notes',
      'Auto-validation for required fields',
      'Mobile-friendly interface',
    ],
    image: customerPortalImage,
  },
  {
    title: 'Payments Integration',
    summary: 'Let customers pay directly in the portal using secure gateways.',
    points: [
      'Built-in support for Stripe and PayPal',
      'Support for multiple currencies',
      'Automatic invoice generation',
      'Payment confirmation email receipts',
    ],
    image: paymentImage,
  },
  {
    title: 'Real-Time Order Tracking',
    summary: 'Offer complete visibility of order status from pickup to delivery.',
    points: [
      'Live tracking map view',
      'Timeline view of each delivery stage',
      'Push/email/SMS notifications for updates',
      'QR code tracking page',
    ],
    image: trackingImage,
  },
  {
    title: 'Dashboard Insights',
    summary: 'A powerful overview of orders, payments, and delivery statuses.',
    points: [
      'Track active, scheduled, and completed orders',
      'View payment history and order totals',
      'Visual indicators for delays or failed attempts',
      'Export data for reporting',
    ],
    image: dashboardImage,
  },
  {
    title: 'Customer Management',
    summary: 'Self-service tools for profile, preferences, and order history.',
    points: [
      'Update company or user profile info',
      'Manage contacts and delivery addresses',
      'Review full order history and receipts',
      'Role-based access controls (if enabled)',
    ],
    image: customerPortalImage,
  },
  {
    title: 'Custom Branding',
    summary: 'Deliver a fully branded customer experience on your domain.',
    points: [
      'Customize logos, colors, and theme',
      'White-labeled URLs and email templates',
      'Embed in your existing website or product',
      'Built for SaaS or private deployments',
    ],
    image: brandingImage,
  },
  {
    title: 'Secure Data Handling',
    summary: 'Privacy-first architecture that protects customer data.',
    points: [
      'All traffic over HTTPS',
      'Encrypted payment and personal info',
      'Role-based access controls',
      'Compliant with modern security standards',
    ],
    image: secureImage,
  },
  {
    title: 'Real-Time Notifications',
    summary: 'Keep customers updated at every stage of the journey.',
    points: [
      'Email, SMS, and in-app alerts',
      'Custom notification templates',
      'Trigger-based messages (status, payment, failed delivery)',
      'Optional unsubscribe or digest modes',
    ],
    image: dashboardImage,
  },
]
---

<section class="relative overflow-hidden">
  <Container class="pb-16 pt-20 sm:pb-20 sm:pt-24 lg:pb-32">
    <!-- Header -->
    <div class="relative flex flex-col items-center text-center">
      <h1 class="max-w-5xl text-4xl font-bold leading-extratight text-blue-100 sm:text-5xl sm:leading-extratight">
        Fleetbase Customer Portal<br />
        <span class="relative inline-block text-nowrap">
          <span class="relative z-10 bg-gradient-to-b from-blue-400 via-blue-400 to-blue-500 bg-clip-text text-transparent">
            A Seamless Experience for Your Customers
          </span>
          <span class="absolute -top-px left-0 -z-10 text-blue-300">
            A Seamless Experience for Your Customers
          </span>
        </span>
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-8 text-zinc-200">
        Empower your customers to manage their orders, track shipments, and make payments — all in one secure, branded portal.
      </p>

      <!-- Buttons -->
      <div class="mt-6 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://console.fleetbase.io/auth"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-blue-500 hover:bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-md transition-all"
        >
          <Icon name="heroicons:rocket-launch-solid" class="h-4 w-4" />
          Try Now
        </a>
        <a
          href="https://github.com/fleetbase/customer-portal"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-white px-5 py-2 text-sm font-semibold text-white hover:bg-white hover:text-black transition-all"
        >
          <Icon name="heroicons:code-bracket-square" class="h-4 w-4" />
          Explore Code
        </a>
      </div>
    </div>

    <!-- Demo Video -->
    <div class="mt-16 flex justify-center px-4 sm:px-6 lg:px-8" data-aos="zoom-in-up">
      <div class="relative w-full max-w-6xl overflow-hidden rounded-3xl border border-zinc-700/40 bg-zinc-900/40 backdrop-blur-sm shadow-[0_20px_80px_rgba(0,0,0,0.3)] transition-transform hover:scale-[1.02] duration-300 ease-in-out">
        <div class="aspect-video w-full">
          <iframe
            src="https://www.youtube.com/embed/_oAhj_uKWYk"
            title="Fleetbase Customer Portal Demo"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full rounded-3xl"
          ></iframe>
        </div>
        <div class="absolute bottom-4 right-4 bg-blue-500 text-white text-xs uppercase tracking-wide px-3 py-1 rounded-full shadow-md">
          Demo
        </div>
      </div>
    </div>

    <!-- Features -->
    {features.map((feature, index) => {
      const isEven = index % 2 === 0
      return (
        <div
          class={`relative mt-32 flex flex-col gap-10 lg:gap-20 ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}
          data-aos="fade-up"
        >
          <!-- Image -->
          <div class="relative w-full lg:w-[65%]">
            <div class="absolute -inset-4 z-[-1] blur-2xl opacity-20 rounded-3xl bg-gradient-to-br from-blue-500 via-indigo-500 to-purple-600"></div>
            <div class="rounded-2xl overflow-hidden border border-blue-200/[.08] bg-white/[.02] shadow-2xl hover:shadow-blue-500/30 transition-all duration-300">
              <Image
                src={feature.image}
                alt={feature.title}
                widths={[1280, 1600, 1920]}
                sizes="(max-width: 768px) 100vw, 1280px"
                class="w-full h-auto"
              />
            </div>
          </div>

          <!-- Text -->
          <div class="w-full lg:w-[35%] flex flex-col justify-center text-white bg-white/5 rounded-2xl p-6 shadow-lg border border-white/10 backdrop-blur-md">
            <h3 class="text-2xl sm:text-3xl font-bold mb-4">{feature.title}</h3>
            <p class="text-base text-zinc-300 mb-4">{feature.summary}</p>
            <ul class="space-y-2 list-disc list-inside text-zinc-200 text-sm sm:text-base mb-6">
              {feature.points.map(point => (
                <li>{point}</li>
              ))}
            </ul>
          </div>
        </div>
      )
    })}
  </Container>
</section>